{
  "spec_version": "1.0",
  "agent_id": "agent-26-pipeline-monitor",
  "agent_name": "pipelineMonitor",
  "tenant_id": "tenant-001",
  "phase": "phase2",
  "description": "Runs every 4 hours via EventBridge cron. Collects KPIs across Sales/Fulfillment/Resurrection pipelines + Recurly MRR/churn, scores 9 KPIs against gold standards (GREEN/YELLOW/RED), posts Block Kit report card to #c-suite-command-center on Slack. RED metrics DM Chuck immediately.",
  "trigger": {
    "type": "cron",
    "schedule": "rate(4 hours)",
    "webhook_source": "EventBridge schedule rule"
  },
  "paths": [
    {
      "path": "/monitor/pipeline",
      "handler": "handle_monitor",
      "description": "Pull all pipeline counts + Recurly metrics, score against gold standards, post report.",
      "inputs": [],
      "outputs": [
        { "name": "ok", "type": "boolean" },
        { "name": "overall", "type": "string", "description": "Emoji-prefixed overall score: 🟢 GREEN | 🟡 YELLOW | 🔴 RED" },
        { "name": "any_red", "type": "boolean", "description": "True if any KPI scored RED" },
        { "name": "kpi_count", "type": "integer" },
        { "name": "elapsed_ms", "type": "integer" },
        { "name": "report", "type": "dict", "description": "Full report with kpis, sales_counts, fulfillment_counts, resurrection_counts, generated_at" },
        { "name": "slack_posted", "type": "boolean" },
        { "name": "chuck_dm_sent", "type": "boolean" }
      ]
    },
    {
      "path": "/ping",
      "handler": "handle_ping",
      "description": "Health check.",
      "inputs": [],
      "outputs": [
        { "name": "ok", "type": "boolean" },
        { "name": "agent", "type": "string" },
        { "name": "status", "type": "string" }
      ]
    }
  ],
  "ssm_params": {
    "required": [
      "GHL_API_KEY",
      "GHL_LOCATION_ID",
      "GHL_PIPELINE_ID"
    ],
    "optional": [
      "GHL_PIPELINE_FULFILLMENT_ID",
      "GHL_PIPELINE_RESURRECTION_ID",
      "RECURLY_API_KEY",
      "RECURLY_SUBDOMAIN",
      "GOLD_STANDARDS_S3_KEY",
      "S3_REPORTS_BUCKET",
      "RDS_HOST",
      "RDS_DB_NAME",
      "RDS_USERNAME",
      "RDS_PASSWORD",
      "SLACK_BOT_TOKEN",
      "SLACK_CHANNEL_COMMAND_CENTER",
      "SLACK_CHUCK_USER_ID"
    ]
  },
  "apis": ["ghl", "recurly", "s3", "slack", "rds"],
  "adapters": {
    "crm": true,
    "billing": true
  },
  "memory": {
    "enabled": false
  },
  "chain_invokes": [],
  "lambda_config": {
    "memory_mb": 1024,
    "timeout_seconds": 180,
    "extra_packages": ["psycopg2-binary"]
  },
  "llm_tasks": [],
  "metadata": {
    "assigned_dev": "Jhosua",
    "spec_authored_by": "Jhosua (back-converted from manual deploy)",
    "spec_authored_date": "2026-04-28",
    "links": {
      "github_path": "agents/26-pipeline-monitor/"
    }
  }
}
