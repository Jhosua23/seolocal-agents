ssm = boto3.client("ssm", region_name="{{ aws_region }}")


def _get_ssm(name, required=True, decrypt=True):
    """Read an SSM parameter. Hard-fail if required and missing."""
    try:
        resp = ssm.get_parameter(Name=name, WithDecryption=decrypt)
        return resp["Parameter"]["Value"]
    except ssm.exceptions.ParameterNotFound:
        if required:
            raise RuntimeError(f"Required SSM param missing: {name}")
        return None


# Required params — agent fails to start if any of these are missing
{%- for p in ssm_required %}
{{ p }} = _get_ssm("{{ p }}", required=True)
{%- endfor %}

# Optional params — agent runs in degraded mode if missing
{%- for p in ssm_optional %}
{{ p }} = _get_ssm("{{ p }}", required=False)
{%- endfor %}


