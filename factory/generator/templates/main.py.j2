# ===========================================================================
# LLM SELECTOR — Chuck's COMPLEX / STANDARD / SIMPLE 3-tier system
# ===========================================================================
LLM_MODEL_REGISTRY = {
    "COMPLEX":  "claude-sonnet-4-6",          # Multi-step reasoning, content gen
    "STANDARD": "claude-haiku-4-5-20251001",  # Classification, extraction (default)
    "SIMPLE":   "amazon.nova-micro-v1:0",     # Lookups, formatting, yes/no
}


def _resolve_model(complexity):
    """Resolve complexity tier to a model ID. Honors LLM_MODEL_OVERRIDES SSM."""
    overrides_raw = _get_ssm("LLM_MODEL_OVERRIDES", required=False)
    if overrides_raw:
        try:
            overrides = json.loads(overrides_raw)
            if complexity in overrides:
                return overrides[complexity]
        except json.JSONDecodeError:
            log.warning("LLM_MODEL_OVERRIDES is not valid JSON, using defaults")
    return LLM_MODEL_REGISTRY.get(complexity, LLM_MODEL_REGISTRY["STANDARD"])


_anthropic_client = None
def _anthropic():
    """Lazy-init Anthropic client."""
    global _anthropic_client
    if _anthropic_client is None:
        api_key = _get_ssm("ANTHROPIC_API_KEY", required=True)
        _anthropic_client = anthropic.Anthropic(api_key=api_key)
    return _anthropic_client


def invoke_llm(complexity, system_prompt, user_message, max_tokens=1024):
    """
    Invoke an LLM at the given complexity tier.
    
    Args:
        complexity: COMPLEX | STANDARD | SIMPLE
        system_prompt: The system prompt
        user_message: User content
        max_tokens: Max output tokens
    
    Returns:
        String response from the LLM
    """
    model = _resolve_model(complexity)
    log.info(f"LLM call: complexity={complexity} model={model}")
    
    client = _anthropic()
    response = client.messages.create(
        model=model,
        max_tokens=max_tokens,
        system=system_prompt,
        messages=[{"role": "user", "content": user_message}],
    )
    return response.content[0].text
