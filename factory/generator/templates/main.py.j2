# ===========================================================================
# ROUTER — dispatches based on path injected by bridge
# ===========================================================================
PATH_HANDLERS = {
    {%- for p in paths %}
    "{{ p.path }}": {{ p.handler }},
    {%- endfor %}
}


@app.entrypoint
def invoke(payload):
    """
    Main entrypoint — bridge injects '_path' field, we route to handler.
    """
    if not isinstance(payload, dict):
        return {"ok": False, "error": "payload_must_be_dict"}
    
    path = payload.get("_path", "{{ paths[0].path }}")
    handler = PATH_HANDLERS.get(path)
    
    if handler is None:
        return {
            "ok": False,
            "error": "unknown_path",
            "path": path,
            "available_paths": list(PATH_HANDLERS.keys()),
        }
    
    try:
        return handler(payload)
    except Exception as e:
        log.exception(f"Handler {handler.__name__} failed")
        return {
            "ok": False,
            "error": "handler_exception",
            "exception_type": type(e).__name__,
            "message": str(e)[:500],
        }


