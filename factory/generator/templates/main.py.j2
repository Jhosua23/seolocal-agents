    """Resolve runtime memory namespace from input field '{{ memory_namespace_key }}'."""
    namespace_value = payload.get("{{ memory_namespace_key }}", "default")
    return f"/tenants/{{ tenant_id }}/agents/{{ agent_name }}/actors/{namespace_value}/"


def memory_write(payload, content):
    """Write to AgentCore Memory. Graceful failure if memory unavailable."""
    # TODO: Replace with Jomar's MemoryClient.write() once interface confirmed
    namespace = _memory_namespace(payload)
    log.info(f"[memory] would write to {namespace}: {content}")
    # Pending Jomar's interface — agent runs without memory write for now
    return {"ok": False, "reason": "memory_not_yet_wired"}


def memory_read(payload, query=None):
    """Read from AgentCore Memory. Graceful failure if memory unavailable."""
    # TODO: Replace with Jomar's MemoryClient.read() once interface confirmed
    namespace = _memory_namespace(payload)
    log.info(f"[memory] would read from {namespace}: query={query}")
    return []  # No memory for now
